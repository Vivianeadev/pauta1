  <div class="archive-overlay" id="archiveOverlay">
    <div class="archive-panel">
      <div class="archive-header"><h3><i class="fas fa-archive"></i> Arquivo de artigos</h3><button class="archive-close" id="archiveCloseBtn"><i class="fas fa-times"></i></button></div>
      <div class="archive-search"><input type="text" id="archiveSearchInput" placeholder="Buscar por título, categoria ou data (ex: 08.04)"></div>
      <div class="archive-list" id="archiveList"></div>
    </div>
  </div>

  <script>
    (function() {
      // ========== 1. SISTEMA DINÂMICO DE IMAGEM (NUMERAÇÃO: DIA + PRIMEIRO NOME .jpg) ==========
      function setupDynamicImage() {
        const imgElement = document.getElementById('dynamicArticleImage');
        if (!imgElement) return;
        
        // Extrair data do artigo (formato "09.04.2026" -> dia/mês "09.04")
        const metaSpans = document.querySelectorAll('.article-meta span');
        let dateStr = '';
        for (let span of metaSpans) {
          if (span.innerText.includes('.') && span.innerText.match(/\d{2}\.\d{2}\.\d{4}/)) {
            dateStr = span.innerText.trim();
            break;
          }
        }
        let dayMonth = '';
        if (dateStr) {
          const parts = dateStr.split('.');
          if (parts.length >= 2) dayMonth = `${parts[0]}.${parts[1]}`; // "09.04"
        }
        
        // Extrair primeiro nome do editor (dentro de #editorSignature strong)
        let firstName = 'viviane';
        const editorStrong = document.querySelector('#editorSignature strong');
        if (editorStrong && editorStrong.innerText.trim()) {
          const fullName = editorStrong.innerText.trim();
          firstName = fullName.split(' ')[0].toLowerCase().replace(/[^a-z0-9]/gi, '');
        } else {
          const fallbackStrong = document.querySelector('.article-text div strong');
          if (fallbackStrong) {
            const fallbackName = fallbackStrong.innerText.trim();
            firstName = fallbackName.split(' ')[0].toLowerCase().replace(/[^a-z0-9]/gi, '');
          }
        }
        
        let finalFilename = '';
        if (dayMonth) {
          finalFilename = `${dayMonth}-${firstName}.jpg`;
        } else {
          finalFilename = `default-${firstName}.jpg`;
        }
        
        const imageBasePath = '/assets/images/';
        const imageSrc = imageBasePath + finalFilename;
        
        imgElement.src = imageSrc;
        imgElement.alt = `Imagem ilustrativa: sistema prisional e direitos humanos - ${finalFilename}`;
        imgElement.onerror = function() {
          if (!this.hasAttribute('data-fallback-triggered')) {
            this.setAttribute('data-fallback-triggered', 'true');
            this.src = 'https://placehold.co/600x400/fefaf5/B8860B?text=Imagem+não+encontrada+('+finalFilename+')';
          }
        };
      }
      
      // ========== 2. SHARE BUTTONS ==========
      function setupShareButtons() {
        const currentUrl = encodeURIComponent(window.location.href);
        const pageTitle = encodeURIComponent(document.title);
        
        const shareFacebook = document.getElementById('shareFacebook');
        const shareX = document.getElementById('shareX');
        const shareLinkedin = document.getElementById('shareLinkedin');
        const shareWhatsapp = document.getElementById('shareWhatsapp');
        const shareTelegram = document.getElementById('shareTelegram');
        const shareInstagram = document.getElementById('shareInstagram');
        
        if (shareFacebook) shareFacebook.href = `https://www.facebook.com/sharer/sharer.php?u=${currentUrl}`;
        if (shareX) shareX.href = `https://twitter.com/intent/tweet?text=${pageTitle}&url=${currentUrl}`;
        if (shareLinkedin) shareLinkedin.href = `https://www.linkedin.com/shareArticle?mini=true&url=${currentUrl}&title=${pageTitle}`;
        if (shareWhatsapp) shareWhatsapp.href = `https://api.whatsapp.com/send?text=${pageTitle}%20${currentUrl}`;
        if (shareTelegram) shareTelegram.href = `https://t.me/share/url?url=${currentUrl}&text=${pageTitle}`;
        
        if (shareInstagram) {
          shareInstagram.addEventListener('click', (e) => {
            e.preventDefault();
            const linkToCopy = window.location.href;
            navigator.clipboard.writeText(linkToCopy).then(() => {
              alert('🔗 Link do artigo copiado! Agora você pode colar no Instagram, Stories ou Direct.');
            }).catch(() => {
              alert('Copie o link manualmente: ' + linkToCopy);
            });
          });
        }
      }
      
      // ========== 3. FUNÇÕES DE ARQUIVO ==========
      function openArchive() { document.getElementById('archiveOverlay').classList.add('active'); document.body.classList.add('archive-open'); renderEmptyArchive(); }
      function closeArchive() { document.getElementById('archiveOverlay').classList.remove('active'); document.body.classList.remove('archive-open'); document.getElementById('archiveSearchInput').value = ''; }
      function renderEmptyArchive() {
        const archiveListDiv = document.getElementById('archiveList');
        archiveListDiv.innerHTML = '<div class="no-results">Nenhum artigo publicado ainda. Em breve, novos conteúdos.</div>';
      }
      const searchInput = document.getElementById('archiveSearchInput');
      if (searchInput) searchInput.addEventListener('input', () => renderEmptyArchive());
      document.getElementById('archiveBtn').addEventListener('click', openArchive);
      document.getElementById('archiveCloseBtn').addEventListener('click', closeArchive);
      document.getElementById('archiveOverlay').addEventListener('click', (e) => { if (e.target === document.getElementById('archiveOverlay')) closeArchive(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeArchive(); });

      // Menu dropdown
      const menuIconBtn = document.getElementById('menuIconBtn');
      const menuDropdown = document.getElementById('menuDropdown');
      const dropdownItems = document.querySelectorAll('.dropdown-item');
      const currentTabLabel = document.getElementById('currentTabLabel');
      menuIconBtn.addEventListener('click', (e) => { e.stopPropagation(); menuDropdown.classList.toggle('active'); });
      document.addEventListener('click', (e) => { if (!menuDropdown.contains(e.target) && !menuIconBtn.contains(e.target)) menuDropdown.classList.remove('active'); });
      
      const pageMap = {
        justica: 'justica.html',
        politica: 'politica.html',
        'saude-mental': 'saude-mental.html',
        tecnologia: 'tecnologia.html',
        seguranca: 'seguranca.html',
        negocios: 'negocios.html',
        global: 'global.html',
        filantropia: 'filantropia.html',
        home: 'index.html'
      };
      dropdownItems.forEach(item => {
        item.addEventListener('click', () => {
          const tab = item.dataset.tab;
          const target = pageMap[tab];
          if (target) { window.location.href = target; } 
          else {
            currentTabLabel.innerText = item.innerText.trim();
            dropdownItems.forEach(i => i.classList.remove('active'));
            item.classList.add('active');
            menuDropdown.classList.remove('active');
          }
        });
      });

      // Newsletter
      document.getElementById('newsletterForm')?.addEventListener('submit', function(e) {
        e.preventDefault();
        const email = this.querySelector('input').value;
        alert(`Obrigado pelo interesse! Em breve você receberá análises futuras em ${email}`);
        this.reset();
      });
      
      setupDynamicImage();
      setupShareButtons();
    })();
  </script>
  <!-- 
    SISTEMA DE IMAGEM COM NUMERAÇÃO:
    Padrão: "DIA.MÊS-PRIMEIRONOME.jpg" -> neste artigo: "09.04-viviane.jpg"
    Basta colocar o arquivo correspondente em /assets/images/09.04-viviane.jpg
  -->
</body>
