    (function() {
      // ========== DADOS DOS SUBTEMAS DE JUSTIÇA & DIREITO (INCLUINDO OS TRÊS ARTIGOS JÁ CRIADOS) ==========
      const justicaSubtopics = [
        { name: "Alienação Parental e seus impactos", slug: "alienacao-parental-entre-a-protecao-e-a-falsa-acusacao" },
        { name: "Direito de família e saúde mental", slug: "direito-de-familia-e-saude-mental" },
